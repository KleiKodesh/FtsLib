<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <Nullable>disable</Nullable>
    <LangVersion>8.0</LangVersion>
    <AssemblyName>FstLib</AssemblyName>
    <RootNamespace>FstLib</RootNamespace>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <Authors>FstLib</Authors>
    <Description>Finite State Transducer (FST) library — a minimal Lucene-style FST for fast dictionary lookups with byte-level construction, TARGET_NEXT optimization, and fixed-length binary-search arcs.</Description>
    <PackageTags>fst;finite-state-transducer;lucene;lookup;index</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/example/FstLib</RepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
  </PropertyGroup>

</Project>

